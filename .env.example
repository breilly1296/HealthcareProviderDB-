# ===========================================
# VerifyMyProvider Environment Configuration
# ===========================================
# Copy to .env and fill in values.
# Lines starting with # are comments; commented-out variables are optional.
#
# Production secret storage: GCP Secret Manager (see .github/workflows/deploy.yml
# `secrets:` block, ~lines 157-164). The Secret Manager name is noted on each
# entry below.

# ===========================================
# Database
# ===========================================
# PostgreSQL connection string (REQUIRED).
# Production: pulled from Secret Manager (DATABASE_URL).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verifymyprovider

# ===========================================
# Server
# ===========================================
# Backend port. Cloud Run overrides to 8080 at runtime.
PORT=3001
NODE_ENV=development

# Frontend URL — used by backend to build absolute links (magic links, OG tags)
# and added to the CORS allowlist in production. NOTE: CORS itself uses a
# hardcoded origin list in packages/backend/src/index.ts plus this variable;
# there is no CORS_ORIGIN env var (any value set is ignored).
FRONTEND_URL=http://localhost:3000

# Pino log level: trace, debug, info, warn, error, fatal. Default: info
# LOG_LEVEL=info

# ===========================================
# Authentication — Magic Link
# ===========================================
# JWT secret for signing access & refresh tokens (REQUIRED for auth).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Secret Manager: JWT_SECRET
# JWT_SECRET=your-jwt-secret-here

# CSRF double-submit cookie signing secret (REQUIRED — middleware/csrf.ts
# throws on import if unset).
# Generate: openssl rand -hex 32
# Secret Manager: CSRF_SECRET
# CSRF_SECRET=your-csrf-secret-here

# Resend API key for magic link emails (REQUIRED for auth).
# Get one at: https://resend.com/api-keys
# Secret Manager: RESEND_API_KEY
# RESEND_API_KEY=re_xxxx

# Base URL for magic link verification links.
# Dev: http://localhost:3001 | Prod: https://verifymyprovider.com
# MAGIC_LINK_BASE_URL=http://localhost:3001

# ===========================================
# Encryption — Insurance Card PII
# ===========================================
# AES-256-GCM key for encrypting subscriberId/groupNumber/rxbin/rxpcn/rxgrp on
# user_insurance_cards (REQUIRED — app throws without it when card storage is
# exercised; see packages/backend/src/lib/encryption.ts:19-27).
# Generate: openssl rand -hex 32   (must decode to exactly 32 bytes; base64
# is also accepted by parseKey() — pick one and stay consistent).
# Secret Manager: INSURANCE_ENCRYPTION_KEY
# INSURANCE_ENCRYPTION_KEY=your-insurance-encryption-key

# Previous encryption key — set to old key DURING rotation, remove after
# /api/v1/admin/rotate-encryption-key completes. Decryption falls back to this
# when the primary key fails (lib/encryption.ts:30-39, 94-114).
# INSURANCE_ENCRYPTION_KEY_PREVIOUS=your-previous-encryption-key

# ===========================================
# Admin Authentication
# ===========================================
# Required for /api/v1/admin/* routes. Endpoints return 503 if unset.
# Generate: openssl rand -base64 32
# Secret Manager: ADMIN_SECRET
# ADMIN_SECRET=your-admin-secret-here

# Comma-separated IPs allowed to hit /admin endpoints. Optional but
# recommended in production (e.g. Cloud Scheduler egress IPs + office VPN).
# Empty / unset = no restriction. Exact match only — no CIDR.
# See packages/backend/src/routes/admin.ts:34-58.
# ADMIN_IP_ALLOWLIST=35.187.132.4,104.132.100.5

# ===========================================
# Google reCAPTCHA v3
# ===========================================
# Backend secret key for server-side verification (REQUIRED in prod —
# without it, captcha middleware logs a warning and skips).
# Get keys at: https://www.google.com/recaptcha/admin
# Secret Manager: RECAPTCHA_SECRET_KEY
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Fail mode when the reCAPTCHA API is unreachable:
#   open   = allow request, fall back to a tighter rate limit
#   closed = block request
# Default: open
# CAPTCHA_FAIL_MODE=open

# reCAPTCHA v3 minimum score threshold (0.0-1.0). Default: 0.5
# CAPTCHA_MIN_SCORE=0.5

# Timeout for reCAPTCHA API calls in ms. Default: 5000
# CAPTCHA_API_TIMEOUT_MS=5000

# Max requests per IP when CAPTCHA service is down. Default: 3
# CAPTCHA_FALLBACK_MAX_REQUESTS=3

# Window for fallback rate limit in ms. Default: 3600000 (1 hour)
# CAPTCHA_FALLBACK_WINDOW_MS=3600000

# ===========================================
# IP Reputation (IPQS) — opt-in
# ===========================================
# Enable IP reputation checking on verification routes. Default: false.
# When false, the middleware no-ops (packages/backend/src/middleware/ipReputation.ts:39).
# IP_REPUTATION_ENABLED=false

# IPQS API key — required when IP_REPUTATION_ENABLED=true.
# Get one at: https://www.ipqualityscore.com/
# IPQS_API_KEY=your-ipqs-api-key

# Score above which a high-risk warning is logged (range 0-100). Default: 85
# IP_REPUTATION_THRESHOLD=85

# ===========================================
# Caching / Redis (optional)
# ===========================================
# Falls back to in-memory rate limiting AND in-memory cache if not set.
# Only safe for single-instance deployments. Use rediss:// to enable TLS
# (lib/redis.ts:51-84).
# REDIS_URL=redis://localhost:6379

# ===========================================
# External APIs
# ===========================================
# Anthropic Claude API for insurance card OCR (model: claude-haiku-4-5-20251001).
# Used by the frontend route packages/frontend/src/app/api/insurance-card/extract/route.ts
# and the backend services/insuranceCardExtractor.ts. Feature disabled if unset.
# Secret Manager: ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=your-anthropic-api-key

# URL for CMS NPPES data downloads (used by import scripts; reference only).
# NPI_DATA_URL=https://download.cms.gov/nppes/NPI_Files.html

# ===========================================
# Frontend (public — NEXT_PUBLIC_* are bundled into the client)
# ===========================================
# Backend API base URL.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Used for sitemap generation, OG tags, magic-link links from the client.
# Default: https://verifymyprovider.com
# NEXT_PUBLIC_SITE_URL=https://verifymyprovider.com

# reCAPTCHA v3 site key (passed as Docker build arg in CI).
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Google Maps JS API key (provider map page).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Search Console verification token (rendered in <head>).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token

# ===========================================
# Analytics (PostHog — public)
# ===========================================
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===========================================
# CI/CD (GitHub Actions secrets — NOT loaded at runtime)
# ===========================================
# These are referenced for completeness; they are configured in repo Secrets
# and consumed only by .github/workflows/*.yml. Do NOT set them in .env.
#
#   GCP_PROJECT_ID                  — target GCP project
#   GCP_WORKLOAD_IDENTITY_PROVIDER  — Workload Identity Federation provider
#   GCP_SERVICE_ACCOUNT             — deploy service account email
#   GCP_REGION                      — hardcoded to us-central1 in workflows
#   FRONTEND_URL                    — also injected into Cloud Run at deploy time
#   SLACK_WEBHOOK_URL               — Optional. Slack incoming webhook URL for
#                                     deploy failure notifications. Create at
#                                     https://api.slack.com/messaging/webhooks
